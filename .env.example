NODE_ENV=development
DATABASE_URL=postgresql://user:pass@host:5432/app

# JWT/session
NEXTAUTH_SECRET=changeme
NEXTAUTH_URL=http://localhost:3000

# OIDC defaults (per-institution overrides live in DB)
AZURE_DEFAULT_TENANT_ID=
AZURE_DEFAULT_CLIENT_ID=
AZURE_DEFAULT_CLIENT_SECRET=

# SAML (example placeholders)
SAML_SP_ENTITY_ID=https://yourapp.com/saml/metadata
SAML_SP_ACS_URL=http://localhost:3000/api/auth/saml/acs
SAML_SP_CERT=---BEGIN CERT---
SAML_SP_KEY=---BEGIN KEY---

# Email
EMAIL_FROM=noreply@yourapp.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Public
NEXT_PUBLIC_APP_NAME=CampusConnect
NEXT_PUBLIC_MAX_PHOTOS=4